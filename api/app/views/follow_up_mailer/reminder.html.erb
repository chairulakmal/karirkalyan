<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Follow-up reminder</title>
  </head>
  <body style="margin:0; padding:0; background-color:#f4f1ea; font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Helvetica,Arial,sans-serif; color:#1a1a2e;">
    <table role="presentation" width="100%" cellpadding="0" cellspacing="0" style="background-color:#f4f1ea; padding:32px 16px;">
      <tr>
        <td align="center">
          <table role="presentation" width="100%" cellpadding="0" cellspacing="0" style="max-width:520px; background-color:#ffffff; border:1px solid #d8d3c4;">
            <tr>
              <td style="padding:28px 32px 8px 32px;">
                <p style="margin:0; font-size:12px; letter-spacing:0.08em; text-transform:uppercase; color:#6b6b7b;">KarirKalyan · Follow-up reminder</p>
                <h1 style="margin:12px 0 0 0; font-size:22px; font-weight:600; color:#1a1a2e;">
                  Time to follow up on <span style="color:#2b4eff;"><%= @application.company %></span>
                </h1>
              </td>
            </tr>
            <tr>
              <td style="padding:16px 32px 8px 32px; font-size:15px; line-height:1.6; color:#3a3a4a;">
                <p style="margin:0 0 16px 0;">
                  Your application for <strong><%= @application.role %></strong> at
                  <strong><%= @application.company %></strong> is marked for follow-up today.
                </p>
                <table role="presentation" cellpadding="0" cellspacing="0" style="margin:0 0 8px 0; font-size:14px; color:#3a3a4a;">
                  <tr>
                    <td style="padding:2px 12px 2px 0; color:#6b6b7b;">Current status</td>
                    <td style="padding:2px 0;"><strong><%= @application.status.tr("_", " ").capitalize %></strong></td>
                  </tr>
                  <tr>
                    <td style="padding:2px 12px 2px 0; color:#6b6b7b;">Follow-up date</td>
                    <td style="padding:2px 0;"><strong><%= @application.follow_up_at&.strftime("%B %-d, %Y") %></strong></td>
                  </tr>
                </table>
              </td>
            </tr>
            <tr>
              <td style="padding:16px 32px 28px 32px;">
                <a href="<%= @url %>" style="display:inline-block; background-color:#2b4eff; color:#f4f1ea; text-decoration:none; font-size:14px; font-weight:500; padding:11px 22px;">
                  Open application
                </a>
              </td>
            </tr>
          </table>
          <p style="max-width:520px; margin:16px auto 0 auto; font-size:12px; line-height:1.5; color:#9a9aa8;">
            You're receiving this because you set a follow-up date on this application in KarirKalyan.
          </p>
        </td>
      </tr>
    </table>
  </body>
</html>
