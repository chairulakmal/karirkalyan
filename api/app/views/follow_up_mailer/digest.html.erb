<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Follow-up reminder</title>
  </head>
  <body style="margin:0; padding:0; background-color:#f4f1ea; font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Helvetica,Arial,sans-serif; color:#1a1a2e;">
    <table role="presentation" width="100%" cellpadding="0" cellspacing="0" style="background-color:#f4f1ea; padding:32px 16px;">
      <tr>
        <td align="center">
          <table role="presentation" width="100%" cellpadding="0" cellspacing="0" style="max-width:520px; background-color:#ffffff; border:1px solid #d8d3c4;">
            <tr>
              <td style="padding:28px 32px 8px 32px;">
                <p style="margin:0; font-size:12px; letter-spacing:0.08em; text-transform:uppercase; color:#6b6b7b;">KarirKalyan · Follow-up reminder</p>
                <h1 style="margin:12px 0 0 0; font-size:22px; font-weight:600; color:#1a1a2e;">
                  <% if @applications.one? %>
                    Time to follow up on <span style="color:#2b4eff;"><%= @applications.first.company %></span>
                  <% else %>
                    You have <span style="color:#2b4eff;"><%= @applications.size %> follow-ups</span> due
                  <% end %>
                </h1>
              </td>
            </tr>

            <% @applications.each do |application| %>
              <tr>
                <td style="padding:20px 32px 4px 32px; border-top:1px solid #ece8dd;">
                  <p style="margin:0 0 10px 0; font-size:15px; line-height:1.6; color:#3a3a4a;">
                    <strong><%= application.role %></strong> at <strong><%= application.company %></strong>
                  </p>
                  <table role="presentation" cellpadding="0" cellspacing="0" style="margin:0 0 12px 0; font-size:14px; color:#3a3a4a;">
                    <tr>
                      <td style="padding:2px 12px 2px 0; color:#6b6b7b;">Current status</td>
                      <td style="padding:2px 0;"><strong><%= application.status.tr("_", " ").capitalize %></strong></td>
                    </tr>
                    <tr>
                      <td style="padding:2px 12px 2px 0; color:#6b6b7b;">Follow-up date</td>
                      <td style="padding:2px 0;"><strong><%= application.follow_up_at&.in_time_zone&.strftime("%B %-d, %Y") %></strong></td>
                    </tr>
                  </table>
                  <a href="<%= @origin %>/applications/<%= application.id %>" style="display:inline-block; background-color:#2b4eff; color:#f4f1ea; text-decoration:none; font-size:14px; font-weight:500; padding:11px 22px;">
                    Open application
                  </a>
                </td>
              </tr>
            <% end %>

            <tr>
              <td style="padding:0 32px 28px 32px;"></td>
            </tr>
          </table>
          <p style="max-width:520px; margin:16px auto 0 auto; font-size:12px; line-height:1.5; color:#9a9aa8;">
            You're receiving this because you set a follow-up date on these applications in KarirKalyan.
          </p>
        </td>
      </tr>
    </table>
  </body>
</html>
