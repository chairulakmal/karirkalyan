source "https://rubygems.org"

gem "rails", "~> 8.1.3"
gem "pg", "~> 1.1"
gem "puma", ">= 5.0"
gem "bootsnap", require: false
gem "thruster", require: false
gem "tzinfo-data", platforms: %i[ windows jruby ]
gem "rack-cors"
gem "rack-attack"

# Auth. webauthn is hand-wired into Devise for passkey sign-in — the
# devise-passkeys extension is not mature enough to lean on (SPEC.md § Passkeys).
gem "devise"
gem "devise-jwt"
gem "webauthn"

# Web Push (RFC 8030) — the follow-up digest's second channel (SPEC.md § Push
# notifications). Also owns VAPID key generation (bin/rails push:vapid).
gem "web-push"

# Background jobs & cache — Postgres-backed, no Redis needed (replaces Sidekiq/Redis).
# Solid Queue runs inside Puma via `plugin :solid_queue` (SOLID_QUEUE_IN_PUMA env var);
# recurring jobs are declared in config/recurring.yml.
gem "solid_queue"
gem "solid_cache"

# API docs — needed in production to serve /api-docs
gem "rswag-api"
gem "rswag-ui"

# Structured single-line JSON logs in production for Railway log aggregation
gem "lograge"

# AI job-URL pre-fill — extracts company/role/notes from a pasted posting URL.
# Official Anthropic SDK; key from ANTHROPIC_API_KEY (no-ops/raises cleanly if unset).
gem "anthropic", "~> 1.44"

# Japanese national holidays for FollowUpReminderJob's dead zones. A gem rather than a
# hardcoded list because 春分の日/秋分の日 move with the equinoxes and 振替休日 is a rule,
# not a date — see SPEC.md § JapanCalendar.
gem "holidays", "~> 11.1"

# Zips the full-account export in memory (Zip::OutputStream.write_buffer).
gem "rubyzip", "~> 3.2", require: "zip"

# Exports::ApplicationsCsv. Explicit because csv stopped being a default gem in Ruby 3.4
# — bundled, but not on the load path unless it is declared.
gem "csv", "~> 3.3"

group :development, :test do
  gem "dotenv-rails"
  gem "debug", platforms: %i[ mri windows ], require: "debug/prelude"
  gem "bundler-audit", require: false
  gem "brakeman", require: false
  gem "rubocop-rails-omakase", require: false
  gem "rspec-rails"
  gem "factory_bot_rails"
  gem "faker"
end

group :test do
  gem "database_cleaner-active_record"
  gem "rswag-specs"
  gem "simplecov", require: false
  gem "prosopite"
  gem "pg_query"
end

gem "honeybadger", "~> 6.6"
