DB_USERNAME=username
DB_PASSWORD=password
DB_HOST=localhost
DB_PORT=5432

FRONTEND_URL=http://localhost:3000

# Generate with: bin/rails secret
DEVISE_JWT_SECRET_KEY=

HONEYBADGER_API_KEY=

# Email SMTP resend.com
# SMTP_PORT defaults to 587
SMTP_HOST=smtp.resend.com
SMTP_USER=resend
SMTP_PASS=
MAILER_FROM=
SMTP_PORT=587

# Redis — Sidekiq jobs + (production) Rails.cache and Rack::Attack throttle store.
REDIS_URL=redis://localhost:6379/0

# HTTP basic-auth for the /sidekiq dashboard. Required in production (the
# dashboard fails closed with 401 if unset). Keep in sync with the web service's
# SIDEKIQ_USERNAME / SIDEKIQ_PASSWORD, which the "For reviewers" footer displays.
SIDEKIQ_USERNAME=
SIDEKIQ_PASSWORD=
