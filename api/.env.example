DB_USERNAME=username
DB_PASSWORD=password
DB_HOST=localhost
DB_PORT=5432

FRONTEND_URL=http://localhost:3000

# Generate with: bin/rails secret
DEVISE_JWT_SECRET_KEY=

HONEYBADGER_API_KEY=

# Anthropic API key for the AI job-URL pre-fill (Claude Haiku 4.5). Pay-as-you-go
# key from console.anthropic.com. If unset, the /applications/prefill endpoint
# returns 503 and the rest of the app works normally.
ANTHROPIC_API_KEY=

# Web Push VAPID keypair. Generate with: bin/rails push:vapid — one pair PER
# ENVIRONMENT (a dev key must never be able to sign a push to the production
# user), never committed. If unset, the push endpoints return 503 and the
# follow-up digest stays email-only; the rest of the app works normally.
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# Email SMTP (Resend). Defaults to port 587 (STARTTLS) when SMTP_PORT is unset.
# NOTE: Railway (and many PaaS) block outbound 587/465. In production use Resend's
# alternate STARTTLS port 2587 (or 2465 for implicit TLS). 587 is fine locally.
SMTP_HOST=smtp.resend.com
SMTP_USER=resend
SMTP_PASS=
MAILER_FROM=
SMTP_PORT=587
