# URL of the Rails API. Server-side only — never exposed to the browser.
API_URL=http://localhost:3001

# Sidekiq demo credentials shown in the in-app "For reviewers" footer so a
# reviewer can open the (basic-auth-protected) /sidekiq dashboard. Read
# server-side only — never shipped as a client bundle var. These must match
# SIDEKIQ_USERNAME / SIDEKIQ_PASSWORD set on the Rails api service.
SIDEKIQ_USERNAME=
SIDEKIQ_PASSWORD=
